DATABASE_URL=postgresql://postgres:1234@localhost:5432/claims-ai

S3_ENDPOINT=s3.us-east-005.backblazeb2.com
S3_ACCESS_KEY=your-backblaze-key-id
S3_SECRET_KEY=your-backblaze-application-key
S3_BUCKET=claims-ai
S3_SECURE=true

QDRANT_URL=https://your-qdrant-cluster-url
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=claim_policies

GEMINI_API_KEY=your-gemini-api-key
GEMINI_BACKUP_API_KEY=your-backup-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Optional disaster-data fallback. Register this app name with ReliefWeb first.
RELIEFWEB_APP_NAME=your-approved-reliefweb-app-name

CORS_ORIGINS=http://localhost:5173
