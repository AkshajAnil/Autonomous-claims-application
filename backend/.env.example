DATABASE_URL=postgresql://claims_user:claims_pass@localhost:5432/claims_db
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=s3.us-west-004.backblazeb2.com
S3_ACCESS_KEY=your-backblaze-key-id
S3_SECRET_KEY=your-backblaze-application-key
S3_BUCKET=claims-ai
S3_SECURE=true

QDRANT_URL=https://your-qdrant-cluster-url
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=claim_policies

GEMINI_API_KEY=your-gemini-api-key
GEMINI_BACKUP_API_KEY=your-backup-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

JWT_SECRET=supersecretkey
JWT_EXPIRATION_MINUTES=120

RELIEFWEB_APP_NAME=your-approved-reliefweb-app-name
CORS_ORIGINS=*
